rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Chat sessions subcollection
      match /chatSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Family members subcollection (Premium feature)
      match /familyMembers/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Attorneys are readable by any authenticated user
    match /attorneys/{attorneyId} {
      allow read: if request.auth != null;
    }

    // Referrals: users can create for themselves, read their own
    match /referrals/{referralId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Policy alerts are readable by any authenticated user
    match /policyAlerts/{alertId} {
      allow read: if request.auth != null;
    }

    // Scraped content - server-side only (no client access)
    match /scrapedContent/{docId} {
      allow read, write: if false;
    }

    // Semantic cache - server-side only
    match /cache/{document=**} {
      allow read, write: if false;
    }
  }
}

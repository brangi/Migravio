# OpenRouter API for AI summaries
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Pinecone for RAG knowledge base (optional - for future Phase 1 enhancement)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=immigration-docs

# Firebase Admin SDK (for local testing only - Cloud Functions auto-initialize)
# Copy the entire JSON content from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_ADMIN_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "your-project", ...}'

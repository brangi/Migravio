# ============================================
# Frontend (apps/web/.env.local)
# ============================================

# Firebase (from Firebase Console → Project settings → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=migravio-ai
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (JSON string of service account — used in API routes)
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# Stripe (from Stripe Dashboard → Developers → API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (from Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=
# Server-side price IDs (for webhook plan detection)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# AI Service URL (where FastAPI is running)
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# Resend (from resend.com → API Keys)
RESEND_API_KEY=

# ============================================
# AI Service (apps/ai-service/.env)
# ============================================

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PINECONE_API_KEY=
PINECONE_INDEX_NAME=immigration-docs
FIREBASE_ADMIN_SERVICE_ACCOUNT=
